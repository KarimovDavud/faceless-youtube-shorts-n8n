# ----------------------------------------------------------------------------
# Copy this file to ".env" and fill in your keys.   cp .env.example .env
# ----------------------------------------------------------------------------

# Groq — free LLM API used to write the script.  https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pexels — free stock video for backgrounds.  https://www.pexels.com/api/
# Optional: if left blank, produce.sh falls back to an ffmpeg-generated gradient.
PEXELS_API_KEY=

# Timezone used by the Schedule Trigger (cron) and the container clock.
TIMEZONE=Asia/Baku

# NOTE: YouTube is NOT an env key. It's connected as an OAuth2 *credential*
# inside the n8n UI (Google Cloud → OAuth client). See docs/SETUP.md.
